# All variables below are read by the Python extractor (packages/extraction) or by
# Vite's dev-server orchestration (apps/web/vite.config.js). None are secrets except
# OPENCODE_API_KEY. This file lives at the repo root — apps/web resolves it two
# directories up regardless of where `npm run dev` is invoked from.

# --- Database (server-side; docker-compose.yml + packages/persistence) ------
POSTGRES_USER=tutor
POSTGRES_PASSWORD=tutor
POSTGRES_DB=tutor
DATABASE_URL=postgresql+psycopg://tutor:tutor@localhost:5432/tutor

# --- apps/api (server-side; apps/api/settings.py) ----------------------------
# API_CORS_ORIGINS is the Vite dev origin below by default even if unset —
# only listed here for discoverability. API_UPLOAD_DIR isn't listed: leave
# it unset so it defaults to <repo root>/data/uploads (an empty string here
# would be read as a real value, not "use the default").
API_CORS_ORIGINS=http://localhost:5173

# --- Extraction service (server-side) ---------------------------------------
LOCAL_EXTRACTOR_PORT=5052
LOCAL_EXTRACTOR_IMAGES_SCALE=2
LOCAL_EXTRACTOR_MAX_IMAGES_SCALE=3
LOCAL_EXTRACTOR_OCR_LANGUAGE=eng
LOCAL_EXTRACTOR_FORCE_OCR_RETRY=true
LOCAL_EXTRACTOR_SOFFICE_TIMEOUT_SECONDS=180
LIBREOFFICE_PATH=C:\Program Files\LibreOffice\program\soffice.com

# --- OpenCode vision (server-side; OPENCODE_API_KEY is a real secret) -------
OPENCODE_API_KEY=
OPENCODE_VISION_MODEL=mimo-v2.5
OPENCODE_VISION_TIMEOUT_MS=90000
OPENCODE_VISION_MAX_TOKENS=1200
OPENCODE_VISION_TEMPERATURE=0.2
OPENCODE_VISION_CONCURRENCY=1
OPENCODE_VISION_PAGE_TEXT_CHARS=1800
OPENCODE_VISION_MAX_IMAGE_BYTES=4194304
OPENCODE_VISION_PROMPT_VERSION=v1
SLIDEVISION_CACHE_NAMESPACE=default
SLIDEVISION_CACHE_PATH=data/slidevision-cache.sqlite

# --- packages/llm (server-side; OPENCODE_API_KEY above is reused) -----------
# OPENCODE_BASE_URL accepts either the bare base ('.../v1') or the full
# '.../v1/chat/completions' endpoint — the client normalizes either form.
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
LLM_MODEL_REASONING=deepseek-v4-pro
LLM_MODEL_FAST=deepseek-v4-flash
LLM_MODEL_VISION=mimo-v2.5
LLM_PURPOSE_INTENT=fast
LLM_PURPOSE_ASSESS=fast
LLM_PURPOSE_GENERATE=fast
LLM_PURPOSE_PLAN=reasoning
LLM_PURPOSE_JUDGE=reasoning
LLM_MAX_CONCURRENCY=4
LLM_TIMEOUT_SECONDS=60
# Per-model USD cost per 1M tokens, "input,output". Unset/missing model ->
# llm_calls.cost_usd is NULL (never guessed — see packages/llm/logging.py).
# LLM_COST_RATE_DEEPSEEK_V4_PRO=
# LLM_COST_RATE_DEEPSEEK_V4_FLASH=
# LLM_COST_RATE_MIMO_V2_5=

# --- Client (browser bundle). VITE_-prefixed vars are inlined into the ------
# bundle by Vite at build time, so nothing that must stay secret may live
# here. VITE_API_BASE_URL is the one variable this project's architecture
# invariants (CLAUDE.md #7) name as always permitted — it points the typed
# apps/web/src/api client at apps/api (uvicorn, see below). It is NOT the
# local extractor's URL: that debug tool always uses the Vite dev-server
# proxy at /local-extractor (apps/web/src/utils/localExtractorApi.js), which
# needs no env var of its own.
VITE_API_BASE_URL=http://localhost:8000
VITE_LOCAL_EXTRACTOR_TIMEOUT_MS=600000

# Documented exception to invariant #7: these are never secrets and are read
# exclusively by browser code (apps/web/src/components/ImageDebugPanel.jsx,
# apps/web/src/utils/imagePipeline.js, apps/web/src/utils/visualDescriptionApi.js)
# to run canvas-based pixel analysis and set client-side fetch defaults. There
# is no server-side equivalent for any of these — see docs/DECISIONS.md.
VITE_OPENCODE_VISION_MODEL=mimo-v2.5
VITE_OPENCODE_VISION_TIMEOUT_MS=120000
VITE_VISUAL_MIN_PICTURE_BOXES=1
VITE_VISUAL_MIN_PICTURE_AREA_PERCENT=12
VITE_VISUAL_MIN_RESIDUAL_RATIO_PERCENT=30
VITE_VISUAL_MIN_EDGE_RATIO_PERCENT=10
VITE_VISUAL_TEXT_MASK_PADDING=3
VITE_VISUAL_MIN_TEXT_BOXES_TO_MASK=1
VITE_VISUAL_MAX_REPEAT_COUNT=1
VITE_VISUAL_ENABLE_RESIDUAL_FALLBACK=false
