      "slide_no": 2,
      "order_index": 3,
      "text": "Merge sort is stable and runs in O(n log n) time in all cases.",
      "provenance": "verbatim",
      "ocr_confidence": null,
      "producer": null,
      "bbox": [
        0.1,
