      "document_id": "00efc422a1f4173aa48dec5801c1503cb3ddfd2829cd15e5c9764150e134dd57",
      "slide_no": 2,
      "order_index": 1,
      "text": "Merge sort splits the input in half recursively.",
      "provenance": "verbatim",
      "ocr_confidence": null,
      "producer": null,
      "bbox": [
        0.1,
        0.223119,
        0.456218,
