      "document_id": "00efc422a1f4173aa48dec5801c1503cb3ddfd2829cd15e5c9764150e134dd57",
      "slide_no": 2,
      "order_index": 2,
      "text": "Each half is sorted independently, then merged in linear time.",
      "provenance": "verbatim",
      "ocr_confidence": null,
      "producer": null,
      "bbox": [
        0.1,
        0.27497,
        0.589739,
        0.297841
      ]
    },
    {
      "block_id": "b_84cd913de854f8a5",
